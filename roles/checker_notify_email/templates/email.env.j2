# This file is managed by the mkbrechtel.sysops.checker_notify_email Ansible role!
# MANUAL CHANGES WILL BE OVERWRITTEN WITHOUT WARNING!

# Email notification configuration
NOTIFY_EMAIL_ENABLED={{ checker_notify_email_enabled | lower }}
NOTIFY_EMAIL_TO="{{ checker_notify_email_to }}"
NOTIFY_EMAIL_FROM="{{ checker_notify_email_from }}"
NOTIFY_EMAIL_SUBJECT_PREFIX="{{ checker_notify_email_subject_prefix }}"

# Notification settings
NOTIFY_EMAIL_ON_WARNING={{ checker_notify_email_on_warning | lower }}
NOTIFY_EMAIL_ON_CRITICAL={{ checker_notify_email_on_critical | lower }}
NOTIFY_EMAIL_ON_RECOVERY={{ checker_notify_email_on_recovery | lower }}
NOTIFY_EMAIL_INCLUDE_OUTPUT={{ checker_notify_email_include_output | lower }}
NOTIFY_EMAIL_MAX_OUTPUT_LINES={{ checker_notify_email_max_output_lines }}

# Rate limiting
NOTIFY_EMAIL_RATE_LIMIT={{ checker_notify_email_rate_limit }}
NOTIFY_EMAIL_RATE_WINDOW={{ checker_notify_email_rate_window }}