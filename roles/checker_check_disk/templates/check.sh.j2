#!/bin/bash
# This file is managed by the mkbrechtel.sysops.checker_check_disk Ansible role!
# MANUAL CHANGES WILL BE OVERWRITTEN WITHOUT WARNING!

OPTIONS=""

{% if checker_check_disk_warning is string and checker_check_disk_warning.endswith('%') %}
OPTIONS="$OPTIONS -w {{ checker_check_disk_warning }}"
{% else %}
OPTIONS="$OPTIONS -w {{ checker_check_disk_warning }}{{ 'MB' if checker_check_disk_units == 'MB' else '' }}"
{% endif %}

{% if checker_check_disk_critical is string and checker_check_disk_critical.endswith('%') %}
OPTIONS="$OPTIONS -c {{ checker_check_disk_critical }}"
{% else %}
OPTIONS="$OPTIONS -c {{ checker_check_disk_critical }}{{ 'MB' if checker_check_disk_units == 'MB' else '' }}"
{% endif %}

{% for path in checker_check_disk_paths %}
OPTIONS="$OPTIONS -p {{ path }}"
{% endfor %}

{% for type in checker_check_disk_exclude_types %}
OPTIONS="$OPTIONS -X {{ type }}"
{% endfor %}

{% for type in checker_check_disk_include_types %}
OPTIONS="$OPTIONS -N {{ type }}"
{% endfor %}

{% if checker_check_disk_local_only %}
OPTIONS="$OPTIONS -l"
{% endif %}

OPTIONS="$OPTIONS -t {{ checker_check_disk_timeout }}"
OPTIONS="$OPTIONS -u {{ checker_check_disk_units }}"

exec /usr/lib/nagios/plugins/check_disk $OPTIONS
