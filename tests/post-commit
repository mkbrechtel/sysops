# When a commit lands on main, sync tests/* into the shared hooks dir so
# every worktree of this repository runs the latest hooks.

set -euo pipefail

branch=$(git symbolic-ref --short HEAD 2>/dev/null || true)
if [ "$branch" != "main" ]; then
    exit 0
fi

hooksdir=$(git rev-parse --git-common-dir)/hooks
worktree=$(git rev-parse --show-toplevel)

shopt -s nullglob
for src in "$worktree"/tests/*; do
    [ -f "$src" ] || continue
    name=$(basename "$src")
    install -m 755 "$src" "$hooksdir/$name"
done
echo "post-commit: synced $(basename "$worktree")/tests/* -> $hooksdir/"
