# Refuse non-fast-forward updates and deletions of main. Branch creation
# and fast-forward updates are allowed; force-push rewrites that would
# orphan commits on main are rejected.

set -euo pipefail

ref=$1
oldrev=$2
newrev=$3
zero="0000000000000000000000000000000000000000"

if [ "$ref" != "refs/heads/main" ]; then
    exit 0
fi

if [ "$oldrev" = "$zero" ]; then
    exit 0
fi

if [ "$newrev" = "$zero" ]; then
    echo "update: refusing to delete main" >&2
    exit 1
fi

if ! git merge-base --is-ancestor "$oldrev" "$newrev"; then
    echo "update: refusing non-fast-forward update to main" >&2
    echo "  $oldrev is not an ancestor of $newrev" >&2
    exit 1
fi
