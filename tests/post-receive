# When this repository receives an update on main, extract tests/* from the
# new tree and install them into the shared hooks dir.

set -euo pipefail

hooksdir=$(git rev-parse --git-dir)/hooks

while read -r _oldrev newrev ref; do
    [ "$ref" = "refs/heads/main" ] || continue

    tmp=$(mktemp -d)
    trap 'rm -rf "$tmp"' EXIT

    if ! git archive "$newrev" tests 2>/dev/null | tar -x -C "$tmp"; then
        echo "post-receive: no tests/ tree at $newrev, skipping" >&2
        continue
    fi

    shopt -s nullglob
    for src in "$tmp"/tests/*; do
        [ -f "$src" ] || continue
        name=$(basename "$src")
        install -m 755 "$src" "$hooksdir/$name"
    done
    echo "post-receive: synced tests/* from $newrev -> $hooksdir/"
done
